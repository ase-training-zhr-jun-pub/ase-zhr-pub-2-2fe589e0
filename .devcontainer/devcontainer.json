{
	"name": "Node.js",
	"image": "ghcr.io/innoq-trainings/agentic-se-image:latest",
	"runArgs": [
		"--init",
		"--privileged"
	],
	"mounts": [
		"source=dind-var-lib-docker,target=/var/lib/docker,type=volume"
	],
	"customizations": {
		"vscode": {
			"extensions": [
				"anthropic.claude-code",
				"esbenp.prettier-vscode",
				"DavidAnson.vscode-markdownlint",
				"bierner.markdown-mermaid",
				"pomdtr.markdown-kroki",
				"ms-python.python"
			]
		}
	},
	"secrets": {
		"ANTHROPIC_API_KEY": {
			"description": "Hier musst du den API-Key eintragen. Du bekommst ihn von einem Trainer"
		}
	},

	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {
	// },

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],
	// "containerEnv": {},
	"postStartCommand": "sudo /usr/local/share/docker-init.sh",

	// SDK (Python-Toolchain) automatisch bei Container-Erstellung installieren,
	// damit es nach einem Neustart/Rebuild nicht manuell nachgeholt werden muss.
	"onCreateCommand": "bash scripts/install-sdk.sh",

	// Backend-Dependencies (FastAPI) in einem venv installieren, sobald eine
	// backend/requirements.txt existiert.
	"postCreateCommand": "bash -c 'if [ -f backend/requirements.txt ]; then python3 -m venv backend/.venv && backend/.venv/bin/pip install -r backend/requirements.txt; fi'"
}