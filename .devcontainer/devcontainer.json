{
	"name": "Node.js",
	"image": "ghcr.io/innoq-trainings/agentic-se-image:latest",
	"runArgs": [
		"--init",
		"--privileged"
	],
	"mounts": [
		"source=dind-var-lib-docker,target=/var/lib/docker,type=volume"
	],
	"customizations": {
		"vscode": {
			"extensions": [
				"anthropic.claude-code",
				"esbenp.prettier-vscode",
				"DavidAnson.vscode-markdownlint",
				"bierner.markdown-mermaid",
				"pomdtr.markdown-kroki",
				"swiftlang.swift-vscode",
				"llvm-vs-code-extensions.lldb-dap"
			]
		}
	},
	"secrets": {
		"ANTHROPIC_API_KEY": {
			"description": "Hier musst du den API-Key eintragen. Du bekommst ihn von einem Trainer"
		}
	},

	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {
	// },

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],
	// "containerEnv": {},
	"postStartCommand": "sudo /usr/local/share/docker-init.sh",

	// SDK (Swift-Toolchain) automatisch bei Container-Erstellung installieren,
	// damit es nach einem Neustart/Rebuild nicht manuell nachgeholt werden muss.
	"onCreateCommand": "bash scripts/install-sdk.sh",

	// Backend-Dependencies auflösen, sobald ein backend/Package.swift existiert.
	"postCreateCommand": "bash -c 'source $HOME/.local/share/swiftly/env.sh 2>/dev/null || true; if [ -f backend/Package.swift ]; then swift package --package-path backend resolve; fi'"
}